{
  "expo": {
    "name": "Imperium Field",
    "slug": "imperium-field",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.imperiumtm.field"
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#e8ddce"
        }
      ],
      [
        "expo-image-picker",
        {
          "cameraPermission": "Imperium Field uses the camera to attach photos of completed work and reported issues to jobs.",
          "photosPermission": "Imperium Field accesses your photo library so you can attach existing photos of completed work and reported issues to jobs."
        }
      ]
    ],
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    }
  }
}
