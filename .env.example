# Supabase project credentials — Project settings → API in the Supabase dashboard.
# Copy this file to .env for local development; set the same variables in
# Netlify (Site configuration → Environment variables) for deploys.
# Without these the app runs on built-in demo data with no persistence.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
